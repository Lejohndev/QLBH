@model IEnumerable<OrderModel>

@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<style>
    .order-card {
        margin-bottom: 2rem;
        border: 1px solid #e3e3e3;
        border-radius: 0.25rem;
    }

    .order-card-header {
        background-color: #f8f9fa;
        padding: 1rem;
        border-bottom: 1px solid #e3e3e3;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .order-card-header h5 {
        margin-bottom: 0;
    }

    .status-badge {
        font-size: 0.9rem;
        padding: 0.5em 0.7em;
    }

    .product-image {
        width: 80px;
        height: 80px;
        object-fit: cover;
    }

    .card-footer {
        background-color: #f8f9fa;
        border-top: 1px solid #e3e3e3;
    }
</style>

<div class="container mt-5">
    <h2 class="mb-4">Lịch sử mua hàng</h2>

    @if (Model.Any())
    {
        foreach (var order in Model)
        {
            <div class="card order-card">
                <div class="card-header order-card-header">
                    <div>
                        <h5 class="mb-0">Mã đơn hàng: @order.OrderCode</h5>
                        <small class="text-muted">Ngày đặt: @order.CreatedDate.ToString("dd/MM/yyyy")</small>
                    </div>
                    <div>
                        @if (order.Status == 1)
                        {
                            <span class="badge bg-success status-badge">Đợi xử lý</span>
                        }
                        else if (order.Status == 0)
                        {
                            <span class="badge bg-primary status-badge">Đã hoàn thành</span>
                        }
                        else if (order.Status == 2)
                        {
                            <span class="badge bg-info status-badge">Đang vận chuyển</span>
                        }
                        else
                        {
                            <span class="badge bg-danger status-badge">Đã hủy</span>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <thead>
                            <tr>
                                <th scope="col">Sản phẩm</th>
                                <th scope="col">Giá</th>
                                <th scope="col">Số lượng</th>
                                <th scope="col" class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in order.OrderDetails)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="~/media/products/@detail.Product.Image" alt="@detail.Product.Name" class="img-thumbnail product-image me-3">
                                            <div>
                                                <h6 class="mb-0">@detail.Product.Name</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@detail.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</td>
                                    <td>@detail.Quantity</td>
                                    <td class="text-end">@((detail.Price * detail.Quantity).ToString("C0", new System.Globalization.CultureInfo("vi-VN")))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <div>
                        @if (order.Status == 1)
                        {
                            <a onclick="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này?')" class="btn btn-danger" asp-action="CancelOrder" asp-controller="Account" asp-route-ordercode="@order.OrderCode">Hủy đơn hàng</a>
                        }
                    </div>
                    <div class="text-end">
                        <strong>Tổng cộng: </strong>
                        @{
                            var total = order.OrderDetails.Sum(d => d.Price * d.Quantity);
                        }
                        <strong>@total.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</strong>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center">
            <p>Bạn chưa có đơn hàng nào.</p>
        </div>
    }
</div>